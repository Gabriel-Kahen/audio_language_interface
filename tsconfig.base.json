{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@audio-language-interface/analysis": ["./modules/analysis/src/index.ts"],
      "@audio-language-interface/compare": ["./modules/compare/src/index.ts"],
      "@audio-language-interface/core": ["./modules/core/src/index.ts"],
      "@audio-language-interface/history": ["./modules/history/src/index.ts"],
      "@audio-language-interface/io": ["./modules/io/src/index.ts"],
      "@audio-language-interface/orchestration": ["./modules/orchestration/src/index.ts"],
      "@audio-language-interface/planning": ["./modules/planning/src/index.ts"],
      "@audio-language-interface/render": ["./modules/render/src/index.ts"],
      "@audio-language-interface/semantics": ["./modules/semantics/src/index.ts"],
      "@audio-language-interface/tools": ["./modules/tools/src/index.ts"],
      "@audio-language-interface/transforms": ["./modules/transforms/src/index.ts"]
    },
    "verbatimModuleSyntax": true,
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}
