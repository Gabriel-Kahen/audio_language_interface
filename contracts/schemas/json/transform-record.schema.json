{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/transform-record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "asset_id",
    "input_version_id",
    "output_version_id",
    "started_at",
    "finished_at",
    "operations"
  ],
  "properties": {
    "schema_version": {
      "$ref": "./common.schema.json#/$defs/schemaVersion"
    },
    "record_id": {
      "$ref": "./common.schema.json#/$defs/transformId"
    },
    "plan_id": {
      "$ref": "./common.schema.json#/$defs/planId"
    },
    "capability_manifest_id": {
      "$ref": "./common.schema.json#/$defs/capabilityManifestId"
    },
    "asset_id": {
      "$ref": "./common.schema.json#/$defs/assetId"
    },
    "input_version_id": {
      "$ref": "./common.schema.json#/$defs/versionId"
    },
    "output_version_id": {
      "$ref": "./common.schema.json#/$defs/versionId"
    },
    "started_at": {
      "$ref": "./common.schema.json#/$defs/isoTimestamp"
    },
    "finished_at": {
      "$ref": "./common.schema.json#/$defs/isoTimestamp"
    },
    "runtime_ms": {
      "type": "number",
      "minimum": 0
    },
    "warnings": {
      "$ref": "./common.schema.json#/$defs/stringArray"
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["operation", "target", "parameters", "status"],
        "properties": {
          "operation": {
            "$ref": "./common.schema.json#/$defs/operationName"
          },
          "target": {
            "$ref": "./common.schema.json#/$defs/editTarget"
          },
          "parameters": {
            "type": "object"
          },
          "status": {
            "$ref": "./common.schema.json#/$defs/operationStatus"
          }
        },
        "allOf": [
          {
            "if": { "properties": { "operation": { "const": "gain" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/gainParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "normalize" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/normalizeParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "trim" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/trimParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "trim_silence" } } },
            "then": {
              "properties": {
                "parameters": {
                  "$ref": "./common.schema.json#/$defs/trimSilenceParameters"
                }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "fade" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/fadeParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "pitch_shift" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/pitchShiftParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "parametric_eq" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/parametricEqParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "high_pass_filter" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/filterParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "low_pass_filter" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/filterParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "high_shelf" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/shelfParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "low_shelf" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/shelfParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "notch_filter" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/notchFilterParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "tilt_eq" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/tiltEqParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "compressor" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/compressorParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "limiter" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/limiterParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "transient_shaper" } } },
            "then": {
              "properties": {
                "parameters": {
                  "$ref": "./common.schema.json#/$defs/transientShaperParameters"
                }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "clipper" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/clipperParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "gate" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/gateParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "time_stretch" } } },
            "then": {
              "properties": {
                "parameters": {
                  "$ref": "./common.schema.json#/$defs/timeStretchRecordedParameters"
                }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "reverse" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/reverseParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "mono_sum" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/monoSumParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "pan" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/panParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "channel_swap" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/channelSwapParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "channel_remap" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/channelRemapParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "stereo_balance_correction" } } },
            "then": {
              "properties": {
                "parameters": {
                  "$ref": "./common.schema.json#/$defs/stereoBalanceCorrectionParameters"
                }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "mid_side_eq" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/midSideEqParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "stereo_width" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/stereoWidthParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "denoise" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/denoiseParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "de_esser" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/deEsserParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "declick" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/declickParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "declip" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/declipParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "dehum" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/dehumParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "reverb" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/reverbParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "delay" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/delayParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "echo" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/echoParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "bitcrush" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/bitcrushParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "distortion" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/distortionParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "saturation" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/saturationParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "flanger" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/flangerParameters" }
              }
            }
          },
          {
            "if": { "properties": { "operation": { "const": "phaser" } } },
            "then": {
              "properties": {
                "parameters": { "$ref": "./common.schema.json#/$defs/phaserParameters" }
              }
            }
          }
        ]
      }
    }
  }
}
