{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/plan-edits-tool-response.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "tool_name", "status", "completed_at"],
  "properties": {
    "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
    "request_id": { "$ref": "./common.schema.json#/$defs/requestId" },
    "tool_name": { "const": "plan_edits" },
    "status": { "$ref": "./common.schema.json#/$defs/toolStatus" },
    "completed_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
    "warnings": { "$ref": "./common.schema.json#/$defs/stringArray" },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "invalid_arguments",
            "provenance_mismatch",
            "invalid_result_contract",
            "handler_failed"
          ]
        },
        "message": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
        "details": { "type": "object" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edit_plan"],
      "properties": {
        "edit_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "plan_id",
            "capability_manifest_id",
            "asset_id",
            "version_id",
            "user_request",
            "goals",
            "steps",
            "created_at"
          ],
          "properties": {
            "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
            "plan_id": { "$ref": "./common.schema.json#/$defs/planId" },
            "capability_manifest_id": {
              "$ref": "./common.schema.json#/$defs/capabilityManifestId"
            },
            "asset_id": { "$ref": "./common.schema.json#/$defs/assetId" },
            "version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "user_request": { "type": "string" },
            "created_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
            "goals": { "$ref": "./common.schema.json#/$defs/stringArray" },
            "constraints": { "$ref": "./common.schema.json#/$defs/stringArray" },
            "verification_targets": { "$ref": "./common.schema.json#/$defs/stringArray" },
            "rationale": { "type": "string" },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "step_id",
                  "operation",
                  "target",
                  "parameters",
                  "expected_effects",
                  "safety_limits"
                ],
                "properties": {
                  "step_id": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
                  "operation": { "$ref": "./common.schema.json#/$defs/operationName" },
                  "target": { "$ref": "./common.schema.json#/$defs/editTarget" },
                  "parameters": { "type": "object" },
                  "expected_effects": { "$ref": "./common.schema.json#/$defs/stringArray" },
                  "safety_limits": { "$ref": "./common.schema.json#/$defs/stringArray" }
                }
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "error" } } },
      "then": { "required": ["error"] }
    },
    {
      "if": { "properties": { "status": { "const": "ok" } } },
      "then": { "required": ["result"] }
    }
  ]
}
