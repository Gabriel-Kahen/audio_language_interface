{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/compare-versions-tool-response.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "tool_name", "status", "completed_at"],
  "properties": {
    "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
    "request_id": { "$ref": "./common.schema.json#/$defs/requestId" },
    "tool_name": { "const": "compare_versions" },
    "status": { "$ref": "./common.schema.json#/$defs/toolStatus" },
    "completed_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
    "warnings": { "$ref": "./common.schema.json#/$defs/stringArray" },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["comparison_report"],
      "properties": {
        "comparison_report": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "comparison_id",
            "baseline",
            "candidate",
            "generated_at",
            "metric_deltas",
            "summary"
          ],
          "properties": {
            "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
            "comparison_id": { "$ref": "./common.schema.json#/$defs/comparisonId" },
            "baseline": { "type": "object" },
            "candidate": { "type": "object" },
            "generated_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
            "metric_deltas": { "type": "array" },
            "semantic_deltas": { "type": "array" },
            "regressions": { "type": "array" },
            "goal_alignment": { "type": "array" },
            "summary": { "type": "object" }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "error" } } },
      "then": { "required": ["error"] }
    },
    {
      "if": { "properties": { "status": { "const": "ok" } } },
      "then": { "required": ["result"] }
    }
  ]
}
