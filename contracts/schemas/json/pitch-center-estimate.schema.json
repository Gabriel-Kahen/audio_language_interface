{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/contracts/pitch-center-estimate.schema.json",
  "title": "PitchCenterEstimate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "voicing",
    "confidence",
    "analyzed_window_count",
    "voiced_window_count",
    "voiced_window_ratio"
  ],
  "properties": {
    "voicing": {
      "type": "string",
      "enum": ["voiced", "mixed", "unvoiced"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "frequency_hz": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "midi_note": {
      "type": "integer"
    },
    "note_name": {
      "type": "string",
      "minLength": 2
    },
    "uncertainty_cents": {
      "type": "number",
      "minimum": 0
    },
    "analyzed_window_count": {
      "type": "integer",
      "minimum": 0
    },
    "voiced_window_count": {
      "type": "integer",
      "minimum": 0
    },
    "voiced_window_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "voicing": {
            "enum": ["voiced", "mixed"]
          }
        }
      },
      "then": {
        "required": ["frequency_hz", "midi_note", "note_name", "uncertainty_cents"]
      }
    },
    {
      "if": {
        "properties": {
          "voicing": {
            "const": "unvoiced"
          }
        }
      },
      "then": {
        "not": {
          "anyOf": [
            { "required": ["frequency_hz"] },
            { "required": ["midi_note"] },
            { "required": ["note_name"] },
            { "required": ["uncertainty_cents"] }
          ]
        }
      }
    }
  ]
}
