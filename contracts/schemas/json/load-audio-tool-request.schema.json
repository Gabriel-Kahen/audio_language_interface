{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/load-audio-tool-request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "tool_name", "arguments", "requested_at"],
  "properties": {
    "schema_version": {
      "$ref": "./common.schema.json#/$defs/schemaVersion"
    },
    "request_id": {
      "$ref": "./common.schema.json#/$defs/requestId"
    },
    "tool_name": {
      "const": "load_audio"
    },
    "requested_at": {
      "$ref": "./common.schema.json#/$defs/isoTimestamp"
    },
    "session_id": {
      "$ref": "./common.schema.json#/$defs/sessionId"
    },
    "asset_id": {
      "$ref": "./common.schema.json#/$defs/assetId"
    },
    "version_id": {
      "$ref": "./common.schema.json#/$defs/versionId"
    },
    "caller": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "arguments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_path"],
      "properties": {
        "input_path": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "output_directory": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "normalization_target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["container_format", "codec", "sample_rate_hz", "channels"],
          "properties": {
            "container_format": {
              "$ref": "./common.schema.json#/$defs/nonEmptyString"
            },
            "codec": {
              "$ref": "./common.schema.json#/$defs/nonEmptyString"
            },
            "sample_rate_hz": {
              "type": "integer",
              "minimum": 1
            },
            "channels": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "tags": {
          "$ref": "./common.schema.json#/$defs/stringArray"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
