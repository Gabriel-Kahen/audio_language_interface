{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/compare-versions-tool-request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "tool_name", "arguments", "requested_at"],
  "properties": {
    "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
    "request_id": { "$ref": "./common.schema.json#/$defs/requestId" },
    "tool_name": { "const": "compare_versions" },
    "requested_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
    "session_id": { "$ref": "./common.schema.json#/$defs/sessionId" },
    "asset_id": { "$ref": "./common.schema.json#/$defs/assetId" },
    "version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
    "caller": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
    "arguments": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_version",
        "candidate_version",
        "baseline_analysis",
        "candidate_analysis"
      ],
      "properties": {
        "baseline_version": {
          "type": "object",
          "required": ["schema_version", "version_id", "asset_id", "lineage", "audio"],
          "properties": {
            "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
            "version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "asset_id": { "$ref": "./common.schema.json#/$defs/assetId" },
            "lineage": { "type": "object" },
            "audio": { "type": "object" },
            "state": { "type": "object" }
          },
          "additionalProperties": false
        },
        "candidate_version": {
          "type": "object",
          "required": ["schema_version", "version_id", "asset_id", "lineage", "audio"],
          "properties": {
            "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
            "version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "asset_id": { "$ref": "./common.schema.json#/$defs/assetId" },
            "parent_version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "lineage": { "type": "object" },
            "audio": { "type": "object" },
            "state": { "type": "object" }
          },
          "additionalProperties": false
        },
        "baseline_analysis": {
          "type": "object",
          "required": [
            "schema_version",
            "report_id",
            "asset_id",
            "version_id",
            "generated_at",
            "analyzer",
            "summary",
            "measurements"
          ],
          "properties": {
            "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
            "report_id": { "$ref": "./common.schema.json#/$defs/analysisId" },
            "asset_id": { "$ref": "./common.schema.json#/$defs/assetId" },
            "version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "generated_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
            "analyzer": { "type": "object" },
            "summary": { "type": "object" },
            "measurements": { "type": "object" }
          },
          "additionalProperties": false
        },
        "candidate_analysis": {
          "type": "object",
          "required": [
            "schema_version",
            "report_id",
            "asset_id",
            "version_id",
            "generated_at",
            "analyzer",
            "summary",
            "measurements"
          ],
          "properties": {
            "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
            "report_id": { "$ref": "./common.schema.json#/$defs/analysisId" },
            "asset_id": { "$ref": "./common.schema.json#/$defs/assetId" },
            "version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "generated_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
            "analyzer": { "type": "object" },
            "summary": { "type": "object" },
            "measurements": { "type": "object" },
            "annotations": { "type": "array" }
          },
          "additionalProperties": false
        },
        "edit_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "plan_id",
            "capability_manifest_id",
            "asset_id",
            "version_id",
            "user_request",
            "created_at",
            "goals",
            "steps"
          ],
          "properties": {
            "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
            "plan_id": { "$ref": "./common.schema.json#/$defs/planId" },
            "capability_manifest_id": {
              "$ref": "./common.schema.json#/$defs/capabilityManifestId"
            },
            "asset_id": { "$ref": "./common.schema.json#/$defs/assetId" },
            "version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "user_request": { "type": "string" },
            "created_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
            "goals": { "$ref": "./common.schema.json#/$defs/stringArray" },
            "constraints": { "$ref": "./common.schema.json#/$defs/stringArray" },
            "verification_targets": {
              "$ref": "./common.schema.json#/$defs/verificationTargetArray"
            },
            "rationale": { "type": "string" },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "step_id",
                  "operation",
                  "target",
                  "parameters",
                  "expected_effects",
                  "safety_limits"
                ],
                "properties": {
                  "step_id": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
                  "operation": { "$ref": "./common.schema.json#/$defs/operationName" },
                  "target": { "$ref": "./common.schema.json#/$defs/editTarget" },
                  "parameters": { "type": "object" },
                  "expected_effects": { "$ref": "./common.schema.json#/$defs/stringArray" },
                  "safety_limits": { "$ref": "./common.schema.json#/$defs/stringArray" }
                },
                "allOf": [
                  {
                    "if": { "properties": { "operation": { "const": "gain" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/gainParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "normalize" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/normalizeParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "trim" } } },
                    "then": {
                      "properties": {
                        "parameters": { "$ref": "./common.schema.json#/$defs/trimParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "trim_silence" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": {
                          "$ref": "./common.schema.json#/$defs/trimSilenceParameters"
                        }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "fade" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/fadeParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "pitch_shift" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/pitchShiftParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "parametric_eq" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": {
                          "$ref": "./common.schema.json#/$defs/parametricEqParameters"
                        }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "high_pass_filter" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/filterParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "low_pass_filter" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/filterParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "high_shelf" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/shelfParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "low_shelf" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/shelfParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "notch_filter" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": {
                          "$ref": "./common.schema.json#/$defs/notchFilterParameters"
                        }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "tilt_eq" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/tiltEqParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "compressor" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/compressorParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "limiter" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/limiterParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "time_stretch" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": {
                          "$ref": "./common.schema.json#/$defs/timeStretchRequestParameters"
                        }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "reverse" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/reverseParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "mono_sum" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/monoSumParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "channel_swap" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": {
                          "$ref": "./common.schema.json#/$defs/channelSwapParameters"
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "properties": { "operation": { "const": "stereo_balance_correction" } }
                    },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": {
                          "$ref": "./common.schema.json#/$defs/stereoBalanceCorrectionParameters"
                        }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "stereo_width" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": {
                          "$ref": "./common.schema.json#/$defs/stereoWidthParameters"
                        }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "denoise" } } },
                    "then": {
                      "properties": {
                        "target": { "$ref": "./common.schema.json#/$defs/fullFileTarget" },
                        "parameters": { "$ref": "./common.schema.json#/$defs/denoiseParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "de_esser" } } },
                    "then": {
                      "properties": {
                        "target": {
                          "$ref": "./common.schema.json#/$defs/fullFileOrTimeRangeTarget"
                        },
                        "parameters": { "$ref": "./common.schema.json#/$defs/deEsserParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "declick" } } },
                    "then": {
                      "properties": {
                        "target": {
                          "$ref": "./common.schema.json#/$defs/fullFileOrTimeRangeTarget"
                        },
                        "parameters": { "$ref": "./common.schema.json#/$defs/declickParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "declip" } } },
                    "then": {
                      "properties": {
                        "target": {
                          "$ref": "./common.schema.json#/$defs/fullFileTarget"
                        },
                        "parameters": { "$ref": "./common.schema.json#/$defs/declipParameters" }
                      }
                    }
                  },
                  {
                    "if": { "properties": { "operation": { "const": "dehum" } } },
                    "then": {
                      "properties": {
                        "target": {
                          "$ref": "./common.schema.json#/$defs/fullFileOrTimeRangeTarget"
                        },
                        "parameters": { "$ref": "./common.schema.json#/$defs/dehumParameters" }
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "comparison_id": { "$ref": "./common.schema.json#/$defs/comparisonId" },
        "generated_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" }
      }
    }
  }
}
