{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/common.schema.json",
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "isoTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "severity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "workspacePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/]).+"
    },
    "hexSha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stringMapOfNumbers": {
      "type": "object",
      "propertyNames": {
        "$ref": "./common.schema.json#/$defs/nonEmptyString"
      },
      "additionalProperties": {
        "type": "number"
      }
    },
    "assetId": {
      "type": "string",
      "pattern": "^asset_[A-Za-z0-9]+$"
    },
    "versionId": {
      "type": "string",
      "pattern": "^ver_[A-Za-z0-9]+$"
    },
    "analysisId": {
      "type": "string",
      "pattern": "^analysis_[A-Za-z0-9]+$"
    },
    "semanticId": {
      "type": "string",
      "pattern": "^semantic_[A-Za-z0-9]+$"
    },
    "planId": {
      "type": "string",
      "pattern": "^plan_[A-Za-z0-9]+$"
    },
    "transformId": {
      "type": "string",
      "pattern": "^transform_[A-Za-z0-9]+$"
    },
    "renderId": {
      "type": "string",
      "pattern": "^render_[A-Za-z0-9]+$"
    },
    "comparisonId": {
      "type": "string",
      "pattern": "^compare_[A-Za-z0-9]+$"
    },
    "sessionId": {
      "type": "string",
      "pattern": "^session_[A-Za-z0-9]+$"
    },
    "requestId": {
      "type": "string",
      "pattern": "^toolreq_[A-Za-z0-9]+$"
    },
    "capabilityManifestId": {
      "type": "string",
      "pattern": "^capmanifest_[A-Za-z0-9]+$"
    },
    "sourceKind": {
      "type": "string",
      "enum": ["file", "bytes", "stream", "generated"]
    },
    "renderKind": {
      "type": "string",
      "enum": ["preview", "final"]
    },
    "comparisonRefType": {
      "type": "string",
      "enum": ["version", "render"]
    },
    "metricDirection": {
      "type": "string",
      "enum": ["increased", "decreased", "unchanged"]
    },
    "toolStatus": {
      "type": "string",
      "enum": ["ok", "error"]
    },
    "capabilityIntentSupport": {
      "type": "string",
      "enum": ["planner_supported", "runtime_only"]
    },
    "operationCategory": {
      "type": "string",
      "enum": ["level", "timing", "tonal", "dynamics", "stereo", "restoration", "effects"]
    },
    "parameterValueType": {
      "type": "string",
      "enum": ["number", "integer", "string", "boolean", "enum"]
    },
    "operationStatus": {
      "type": "string",
      "enum": ["applied", "skipped", "failed"]
    },
    "goalStatus": {
      "type": "string",
      "enum": ["met", "mostly_met", "not_met", "unknown"]
    },
    "verificationTargetKind": {
      "type": "string",
      "enum": ["analysis_metric", "semantic_delta", "regression_guard"]
    },
    "verificationComparison": {
      "type": "string",
      "enum": ["increase_by", "decrease_by", "at_most", "at_least", "within", "present", "absent"]
    },
    "nodeType": {
      "type": "string",
      "enum": [
        "audio_asset",
        "audio_version",
        "analysis_report",
        "semantic_profile",
        "edit_plan",
        "transform_record",
        "render_artifact",
        "comparison_report"
      ]
    },
    "relation": {
      "type": "string",
      "enum": [
        "has_version",
        "analyzed_as",
        "described_as",
        "planned_from",
        "executed_as",
        "produced",
        "rendered_as",
        "compared_to",
        "belongs_to"
      ]
    },
    "operationName": {
      "type": "string",
      "enum": [
        "gain",
        "normalize",
        "trim",
        "trim_silence",
        "fade",
        "pitch_shift",
        "parametric_eq",
        "high_pass_filter",
        "low_pass_filter",
        "high_shelf",
        "low_shelf",
        "notch_filter",
        "tilt_eq",
        "compressor",
        "limiter",
        "transient_shaper",
        "clipper",
        "gate",
        "time_stretch",
        "reverse",
        "mono_sum",
        "pan",
        "channel_swap",
        "channel_remap",
        "stereo_balance_correction",
        "mid_side_eq",
        "stereo_width",
        "denoise",
        "de_esser",
        "declick",
        "dehum",
        "reverb",
        "delay",
        "echo",
        "bitcrush",
        "distortion",
        "saturation",
        "flanger",
        "phaser"
      ]
    },
    "targetScope": {
      "type": "string",
      "enum": ["full_file", "time_range", "segment", "channel", "frequency_region"]
    },
    "fullFileTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope"],
      "properties": {
        "scope": {
          "const": "full_file"
        }
      }
    },
    "timeRangeTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "start_seconds", "end_seconds"],
      "properties": {
        "scope": {
          "const": "time_range"
        },
        "start_seconds": {
          "type": "number",
          "minimum": 0
        },
        "end_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "segmentTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "segment_id"],
      "properties": {
        "scope": {
          "const": "segment"
        },
        "segment_id": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "channelTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "channel"],
      "properties": {
        "scope": {
          "const": "channel"
        },
        "channel": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "frequencyRegionTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "bands_hz"],
      "properties": {
        "scope": {
          "const": "frequency_region"
        },
        "bands_hz": {
          "type": "array",
          "items": {
            "type": "number",
            "minimum": 0
          },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "editTarget": {
      "oneOf": [
        {
          "$ref": "./common.schema.json#/$defs/fullFileTarget"
        },
        {
          "$ref": "./common.schema.json#/$defs/timeRangeTarget"
        },
        {
          "$ref": "./common.schema.json#/$defs/segmentTarget"
        },
        {
          "$ref": "./common.schema.json#/$defs/channelTarget"
        },
        {
          "$ref": "./common.schema.json#/$defs/frequencyRegionTarget"
        }
      ]
    },
    "verificationTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_id", "goal", "label", "kind", "comparison"],
      "properties": {
        "target_id": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "goal": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "kind": {
          "$ref": "./common.schema.json#/$defs/verificationTargetKind"
        },
        "comparison": {
          "$ref": "./common.schema.json#/$defs/verificationComparison"
        },
        "metric": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "semantic_label": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "regression_kind": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "threshold": {
          "type": "number"
        },
        "tolerance": {
          "type": "number",
          "minimum": 0
        },
        "target": {
          "$ref": "./common.schema.json#/$defs/editTarget"
        },
        "rationale": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": { "const": "analysis_metric" }
            }
          },
          "then": {
            "required": ["metric"],
            "properties": {
              "metric": {
                "$ref": "./common.schema.json#/$defs/nonEmptyString"
              }
            },
            "oneOf": [
              {
                "properties": {
                  "comparison": {
                    "enum": ["increase_by", "decrease_by", "at_most", "at_least"]
                  },
                  "threshold": {
                    "type": "number"
                  }
                },
                "required": ["threshold"]
              },
              {
                "properties": {
                  "comparison": { "const": "within" },
                  "threshold": {
                    "type": "number"
                  },
                  "tolerance": {
                    "type": "number",
                    "minimum": 0
                  }
                },
                "required": ["threshold", "tolerance"]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": { "const": "semantic_delta" }
            }
          },
          "then": {
            "required": ["semantic_label"],
            "properties": {
              "semantic_label": {
                "$ref": "./common.schema.json#/$defs/nonEmptyString"
              },
              "comparison": {
                "enum": ["present", "absent"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": { "const": "regression_guard" }
            }
          },
          "then": {
            "required": ["regression_kind"],
            "properties": {
              "regression_kind": {
                "$ref": "./common.schema.json#/$defs/nonEmptyString"
              },
              "comparison": {
                "enum": ["present", "absent"]
              }
            }
          }
        }
      ]
    },
    "verificationTargetItem": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "./common.schema.json#/$defs/verificationTarget"
        }
      ]
    },
    "verificationTargetArray": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/verificationTargetItem"
      }
    },
    "verificationTargetResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_id", "goal", "label", "kind", "comparison", "status"],
      "properties": {
        "target_id": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "goal": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "kind": {
          "$ref": "./common.schema.json#/$defs/verificationTargetKind"
        },
        "comparison": {
          "$ref": "./common.schema.json#/$defs/verificationComparison"
        },
        "metric": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "semantic_label": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "regression_kind": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "threshold": {
          "type": "number"
        },
        "tolerance": {
          "type": "number",
          "minimum": 0
        },
        "target": {
          "$ref": "./common.schema.json#/$defs/editTarget"
        },
        "rationale": {
          "type": "string"
        },
        "status": {
          "$ref": "./common.schema.json#/$defs/goalStatus"
        },
        "observed_delta": {
          "type": "number"
        },
        "observed_value": {
          "type": "number"
        },
        "observed_confidence": {
          "$ref": "./common.schema.json#/$defs/confidence"
        },
        "observed_severity": {
          "$ref": "./common.schema.json#/$defs/severity"
        },
        "evidence": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": { "const": "analysis_metric" }
            }
          },
          "then": {
            "required": ["metric"],
            "properties": {
              "metric": {
                "$ref": "./common.schema.json#/$defs/nonEmptyString"
              }
            },
            "oneOf": [
              {
                "properties": {
                  "comparison": {
                    "enum": ["increase_by", "decrease_by", "at_most", "at_least"]
                  },
                  "threshold": {
                    "type": "number"
                  }
                },
                "required": ["threshold"]
              },
              {
                "properties": {
                  "comparison": { "const": "within" },
                  "threshold": {
                    "type": "number"
                  },
                  "tolerance": {
                    "type": "number",
                    "minimum": 0
                  }
                },
                "required": ["threshold", "tolerance"]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kind": { "const": "semantic_delta" }
            }
          },
          "then": {
            "required": ["semantic_label"],
            "properties": {
              "semantic_label": {
                "$ref": "./common.schema.json#/$defs/nonEmptyString"
              },
              "comparison": {
                "enum": ["present", "absent"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": { "const": "regression_guard" }
            }
          },
          "then": {
            "required": ["regression_kind"],
            "properties": {
              "regression_kind": {
                "$ref": "./common.schema.json#/$defs/nonEmptyString"
              },
              "comparison": {
                "enum": ["present", "absent"]
              }
            }
          }
        }
      ]
    },
    "verificationTargetResultArray": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/verificationTargetResult"
      }
    },
    "fullFileOrTimeRangeTarget": {
      "oneOf": [
        {
          "$ref": "./common.schema.json#/$defs/fullFileTarget"
        },
        {
          "$ref": "./common.schema.json#/$defs/timeRangeTarget"
        }
      ]
    },
    "gainParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gain_db"],
      "properties": {
        "gain_db": {
          "type": "number"
        }
      }
    },
    "normalizeParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["peak", "integrated_lufs"]
        },
        "target_peak_dbfs": {
          "type": "number",
          "maximum": 0
        },
        "measured_peak_dbfs": {
          "type": "number",
          "maximum": 0
        },
        "target_integrated_lufs": {
          "type": "number"
        },
        "measured_integrated_lufs": {
          "type": "number"
        },
        "max_true_peak_dbtp": {
          "type": "number",
          "maximum": 0
        },
        "measured_true_peak_dbtp": {
          "type": "number",
          "maximum": 0
        },
        "applied_gain_db": {
          "type": "number"
        },
        "estimated_integrated_lufs": {
          "type": "number"
        },
        "estimated_true_peak_dbtp": {
          "type": "number"
        },
        "gain_limited_by_true_peak": {
          "type": "boolean"
        }
      },
      "oneOf": [
        {
          "properties": {
            "mode": { "const": "peak" },
            "target_peak_dbfs": true
          },
          "required": ["mode", "target_peak_dbfs"]
        },
        {
          "properties": {
            "mode": { "const": "integrated_lufs" },
            "target_integrated_lufs": true
          },
          "required": ["mode", "target_integrated_lufs"]
        }
      ]
    },
    "trimParameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start_seconds": {
          "type": "number",
          "minimum": 0
        },
        "end_seconds": {
          "type": "number",
          "minimum": 0
        },
        "duration_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "trimSilenceParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["threshold_dbfs", "trim_leading", "trim_trailing"],
      "properties": {
        "threshold_dbfs": {
          "type": "number",
          "minimum": -80,
          "maximum": 0
        },
        "trim_leading": {
          "type": "boolean"
        },
        "trim_trailing": {
          "type": "boolean"
        },
        "window_seconds": {
          "type": "number",
          "minimum": 0.001,
          "maximum": 10
        },
        "result_duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "trimmed_duration_seconds": {
          "type": "number",
          "minimum": 0
        }
      },
      "anyOf": [
        {
          "properties": {
            "trim_leading": {
              "const": true
            }
          },
          "required": ["trim_leading"]
        },
        {
          "properties": {
            "trim_trailing": {
              "const": true
            }
          },
          "required": ["trim_trailing"]
        }
      ]
    },
    "fadeParameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fade_in_seconds": {
          "type": "number",
          "minimum": 0
        },
        "fade_out_seconds": {
          "type": "number",
          "minimum": 0
        },
        "fade_out_start_seconds": {
          "type": "number",
          "minimum": 0
        }
      },
      "anyOf": [
        {
          "properties": {
            "fade_in_seconds": {
              "type": "number",
              "minimum": 0
            }
          },
          "required": ["fade_in_seconds"]
        },
        {
          "properties": {
            "fade_out_seconds": {
              "type": "number",
              "minimum": 0
            }
          },
          "required": ["fade_out_seconds"]
        }
      ]
    },
    "pitchShiftParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["semitones"],
      "properties": {
        "semitones": {
          "type": "number",
          "minimum": -24,
          "maximum": 24
        },
        "pitch_ratio": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "asetrate_hz": {
          "type": "integer",
          "minimum": 1
        },
        "tempo_ratio": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "atempo_factors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number",
            "minimum": 0.5,
            "maximum": 2
          }
        }
      }
    },
    "parametricEqBand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "frequency_hz", "gain_db", "q"],
      "properties": {
        "type": {
          "const": "bell"
        },
        "frequency_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "gain_db": {
          "type": "number"
        },
        "q": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "parametricEqParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bands"],
      "properties": {
        "bands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "./common.schema.json#/$defs/parametricEqBand"
          }
        }
      }
    },
    "filterParameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frequency_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "cutoff_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "slope_db_per_octave": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "oneOf": [
        {
          "properties": {
            "frequency_hz": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "required": ["frequency_hz"]
        },
        {
          "properties": {
            "cutoff_hz": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "required": ["cutoff_hz"]
        }
      ]
    },
    "shelfParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frequency_hz", "gain_db", "q"],
      "properties": {
        "frequency_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "gain_db": {
          "type": "number",
          "minimum": -24,
          "maximum": 24
        },
        "q": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "notchFilterParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frequency_hz", "q"],
      "properties": {
        "frequency_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "q": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "tiltEqParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pivot_frequency_hz", "gain_db", "q"],
      "properties": {
        "pivot_frequency_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "gain_db": {
          "type": "number",
          "minimum": -24,
          "maximum": 24
        },
        "q": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "compressorParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["threshold_db", "ratio", "attack_ms", "release_ms"],
      "properties": {
        "threshold_db": {
          "type": "number",
          "maximum": 0
        },
        "ratio": {
          "type": "number",
          "exclusiveMinimum": 1
        },
        "attack_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "release_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "knee_db": {
          "type": "number",
          "minimum": 0
        },
        "makeup_gain_db": {
          "type": "number"
        }
      }
    },
    "limiterParameters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ceiling_dbtp"],
      "properties": {
        "ceiling_dbtp": {
