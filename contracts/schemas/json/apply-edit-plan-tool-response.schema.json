{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/apply-edit-plan-tool-response.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "tool_name", "status", "completed_at"],
  "properties": {
    "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
    "request_id": { "$ref": "./common.schema.json#/$defs/requestId" },
    "tool_name": { "const": "apply_edit_plan" },
    "status": { "$ref": "./common.schema.json#/$defs/toolStatus" },
    "completed_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
    "warnings": { "$ref": "./common.schema.json#/$defs/stringArray" },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_version", "transform_record", "commands"],
      "properties": {
        "output_version": {
          "type": "object",
          "required": ["schema_version", "version_id", "asset_id", "lineage", "audio"],
          "properties": {
            "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
            "version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "asset_id": { "$ref": "./common.schema.json#/$defs/assetId" },
            "parent_version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "lineage": { "type": "object" },
            "audio": { "type": "object" },
            "state": { "type": "object" }
          },
          "additionalProperties": false
        },
        "transform_record": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "record_id",
            "asset_id",
            "input_version_id",
            "output_version_id",
            "started_at",
            "finished_at",
            "operations"
          ],
          "properties": {
            "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
            "record_id": { "$ref": "./common.schema.json#/$defs/transformId" },
            "plan_id": { "$ref": "./common.schema.json#/$defs/planId" },
            "asset_id": { "$ref": "./common.schema.json#/$defs/assetId" },
            "input_version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "output_version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "started_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
            "finished_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
            "runtime_ms": { "type": "number", "minimum": 0 },
            "operations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["operation", "parameters", "status"],
                "properties": {
                  "operation": { "$ref": "./common.schema.json#/$defs/operationName" },
                  "parameters": { "type": "object" },
                  "status": { "$ref": "./common.schema.json#/$defs/operationStatus" }
                }
              }
            }
          }
        },
        "commands": {
          "type": "array",
          "items": { "$ref": "./common.schema.json#/$defs/toolCommand" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "error" } } },
      "then": { "required": ["error"] }
    },
    {
      "if": { "properties": { "status": { "const": "ok" } } },
      "then": { "required": ["result"] }
    }
  ]
}
