{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/describe-runtime-capabilities-tool-request.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "tool_name", "arguments", "requested_at"],
  "properties": {
    "schema_version": {
      "$ref": "./common.schema.json#/$defs/schemaVersion"
    },
    "request_id": {
      "$ref": "./common.schema.json#/$defs/requestId"
    },
    "tool_name": {
      "const": "describe_runtime_capabilities"
    },
    "arguments": {
      "type": "object",
      "additionalProperties": false
    },
    "requested_at": {
      "$ref": "./common.schema.json#/$defs/isoTimestamp"
    },
    "session_id": {
      "$ref": "./common.schema.json#/$defs/sessionId"
    },
    "caller": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    }
  }
}
