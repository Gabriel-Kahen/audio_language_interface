{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/interpret-request-tool-response.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "tool_name", "status", "completed_at"],
  "properties": {
    "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
    "request_id": { "$ref": "./common.schema.json#/$defs/requestId" },
    "tool_name": { "const": "interpret_request" },
    "status": { "$ref": "./common.schema.json#/$defs/toolStatus" },
    "completed_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
    "warnings": { "$ref": "./common.schema.json#/$defs/stringArray" },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
        "message": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
        "details": { "type": "object" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent_interpretation"],
      "properties": {
        "intent_interpretation": { "$ref": "./intent-interpretation.schema.json" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "error" } } },
      "then": { "required": ["error"] }
    },
    {
      "if": { "properties": { "status": { "const": "ok" } } },
      "then": { "required": ["result"] }
    }
  ]
}
