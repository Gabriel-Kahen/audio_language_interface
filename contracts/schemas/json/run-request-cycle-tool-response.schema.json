{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/run-request-cycle-tool-response.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "tool_name", "status", "completed_at"],
  "properties": {
    "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
    "request_id": { "$ref": "./common.schema.json#/$defs/requestId" },
    "tool_name": { "const": "run_request_cycle" },
    "status": { "$ref": "./common.schema.json#/$defs/toolStatus" },
    "completed_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
    "warnings": { "$ref": "./common.schema.json#/$defs/stringArray" },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
        "message": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
        "details": { "type": "object" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_kind",
        "asset",
        "input_version",
        "input_analysis",
        "follow_up_resolution",
        "output_version",
        "output_analysis",
        "version_comparison_report",
        "baseline_render",
        "candidate_render",
        "render_comparison_report",
        "session_graph",
        "trace"
      ],
      "properties": {
        "result_kind": {
          "type": "string",
          "enum": ["applied", "reverted"]
        },
        "asset": { "$ref": "./audio-asset.schema.json" },
        "input_version": { "$ref": "./audio-version.schema.json" },
        "input_analysis": { "$ref": "./analysis-report.schema.json" },
        "follow_up_resolution": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "resolved_user_request", "source"],
              "properties": {
                "kind": { "const": "apply" },
                "resolved_user_request": {
                  "$ref": "./common.schema.json#/$defs/nonEmptyString"
                },
                "source": {
                  "type": "string",
                  "enum": ["direct_request", "repeat_last_request", "try_another_version"]
                },
                "input_version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
                "branch_id": {
                  "type": "string",
                  "pattern": "^branch_[A-Za-z0-9_]+$"
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "target_version_id", "source"],
              "properties": {
                "kind": { "const": "revert" },
                "target_version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
                "source": {
                  "type": "string",
                  "enum": ["less", "undo", "revert"]
                }
              }
            }
          ]
        },
        "semantic_profile": { "$ref": "./semantic-profile.schema.json" },
        "edit_plan": { "$ref": "./edit-plan.schema.json" },
        "output_version": { "$ref": "./audio-version.schema.json" },
        "transform_record": { "$ref": "./transform-record.schema.json" },
        "commands": {
          "type": "array",
          "items": { "$ref": "./common.schema.json#/$defs/toolCommand" }
        },
        "output_analysis": { "$ref": "./analysis-report.schema.json" },
        "version_comparison_report": { "$ref": "./comparison-report.schema.json" },
        "baseline_render": { "$ref": "./render-artifact.schema.json" },
        "candidate_render": { "$ref": "./render-artifact.schema.json" },
        "render_comparison_report": { "$ref": "./comparison-report.schema.json" },
        "session_graph": { "$ref": "./session-graph.schema.json" },
        "revision": {
          "type": "object",
          "additionalProperties": false,
          "required": ["should_revise", "rationale", "source"],
          "properties": {
            "should_revise": { "type": "boolean" },
            "rationale": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
            "source": {
              "type": "string",
              "enum": ["disabled", "default_policy", "caller"]
            }
          }
        },
        "iterations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "iteration",
              "input_version",
              "output_version",
              "input_analysis",
              "output_analysis",
              "edit_plan",
              "comparison_report",
              "transform_record",
              "commands"
            ],
            "properties": {
              "iteration": { "type": "integer", "minimum": 1 },
              "input_version": { "$ref": "./audio-version.schema.json" },
              "output_version": { "$ref": "./audio-version.schema.json" },
              "input_analysis": { "$ref": "./analysis-report.schema.json" },
              "output_analysis": { "$ref": "./analysis-report.schema.json" },
              "semantic_profile": { "$ref": "./semantic-profile.schema.json" },
              "edit_plan": { "$ref": "./edit-plan.schema.json" },
              "comparison_report": { "$ref": "./comparison-report.schema.json" },
              "transform_record": { "$ref": "./transform-record.schema.json" },
              "commands": {
                "type": "array",
                "items": { "$ref": "./common.schema.json#/$defs/toolCommand" }
              }
            }
          }
        },
        "trace": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["stage", "status", "started_at", "completed_at", "attempts"],
            "properties": {
              "stage": {
                "type": "string",
                "enum": [
                  "import",
                  "analyze_input",
                  "resolve_follow_up",
                  "prepare_follow_up_branch",
                  "load_follow_up_input",
                  "load_revert_target",
                  "semantic_profile",
                  "plan",
                  "apply",
                  "analyze_output",
                  "render_baseline",
                  "render_candidate",
                  "compare"
                ]
              },
              "status": {
                "type": "string",
                "enum": ["ok", "error"]
              },
              "started_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
              "completed_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
              "attempts": { "type": "integer", "minimum": 1 },
              "pass": { "type": "integer", "minimum": 1 },
              "message": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "error" } } },
      "then": { "required": ["error"] }
    },
    {
      "if": { "properties": { "status": { "const": "ok" } } },
      "then": { "required": ["result"] }
    }
  ]
}
