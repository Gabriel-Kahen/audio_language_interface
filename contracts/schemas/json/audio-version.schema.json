{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/audio-version.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "version_id", "asset_id", "lineage", "audio"],
  "properties": {
    "schema_version": {
      "$ref": "./common.schema.json#/$defs/schemaVersion"
    },
    "version_id": {
      "$ref": "./common.schema.json#/$defs/versionId"
    },
    "asset_id": {
      "$ref": "./common.schema.json#/$defs/assetId"
    },
    "parent_version_id": {
      "$ref": "./common.schema.json#/$defs/versionId"
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "created_by"],
      "properties": {
        "created_at": {
          "$ref": "./common.schema.json#/$defs/isoTimestamp"
        },
        "created_by": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "reason": {
          "type": "string"
        },
        "plan_id": {
          "$ref": "./common.schema.json#/$defs/planId"
        },
        "transform_record_id": {
          "$ref": "./common.schema.json#/$defs/transformId"
        }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["storage_ref", "sample_rate_hz", "channels", "duration_seconds", "frame_count"],
      "properties": {
        "storage_ref": {
          "$ref": "./common.schema.json#/$defs/workspacePath"
        },
        "sample_rate_hz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "channels": {
          "type": "integer",
          "minimum": 1
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "frame_count": {
          "type": "integer",
          "minimum": 0
        },
        "channel_layout": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "is_original": {
          "type": "boolean"
        },
        "is_preview": {
          "type": "boolean"
        }
      }
    }
  }
}
