{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/intent-interpretation.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "interpretation_id",
    "interpretation_policy",
    "asset_id",
    "version_id",
    "analysis_report_id",
    "semantic_profile_id",
    "user_request",
    "normalized_request",
    "request_classification",
    "next_action",
    "normalized_objectives",
    "candidate_descriptors",
    "confidence",
    "provider",
    "generated_at",
    "rationale"
  ],
  "properties": {
    "schema_version": {
      "$ref": "./common.schema.json#/$defs/schemaVersion"
    },
    "interpretation_id": {
      "$ref": "./common.schema.json#/$defs/interpretationId"
    },
    "interpretation_policy": {
      "$ref": "./common.schema.json#/$defs/interpretationPolicy"
    },
    "asset_id": {
      "$ref": "./common.schema.json#/$defs/assetId"
    },
    "version_id": {
      "$ref": "./common.schema.json#/$defs/versionId"
    },
    "analysis_report_id": {
      "$ref": "./common.schema.json#/$defs/analysisId"
    },
    "semantic_profile_id": {
      "$ref": "./common.schema.json#/$defs/semanticId"
    },
    "user_request": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "normalized_request": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "request_classification": {
      "$ref": "./common.schema.json#/$defs/plannerRequestClass"
    },
    "next_action": {
      "$ref": "./common.schema.json#/$defs/interpretationNextAction"
    },
    "normalized_objectives": {
      "$ref": "./common.schema.json#/$defs/stringArray"
    },
    "candidate_descriptors": {
      "$ref": "./common.schema.json#/$defs/stringArray"
    },
    "descriptor_hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "status"],
        "properties": {
          "label": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
          "status": {
            "$ref": "./common.schema.json#/$defs/descriptorHypothesisStatus"
          },
          "supported_by": { "$ref": "./common.schema.json#/$defs/stringArray" },
          "contradicted_by": { "$ref": "./common.schema.json#/$defs/stringArray" },
          "needs_more_evidence": { "$ref": "./common.schema.json#/$defs/stringArray" },
          "rationale": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "label"],
        "properties": {
          "kind": {
            "$ref": "./common.schema.json#/$defs/interpretationConstraintKind"
          },
          "label": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
          "value": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
          "rationale": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
        }
      }
    },
    "region_intents": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["scope"],
            "properties": {
              "scope": { "const": "full_file" },
              "rationale": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["scope", "start_seconds", "end_seconds"],
            "properties": {
              "scope": { "const": "time_range" },
              "start_seconds": { "type": "number", "minimum": 0 },
              "end_seconds": { "type": "number", "minimum": 0 },
              "rationale": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["scope", "reference"],
            "properties": {
              "scope": { "const": "segment_reference" },
              "reference": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
              "rationale": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
            }
          }
        ]
      }
    },
    "candidate_interpretations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "normalized_request",
          "request_classification",
          "next_action",
          "normalized_objectives",
          "candidate_descriptors",
          "confidence",
          "rationale"
        ],
        "properties": {
          "normalized_request": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
          "request_classification": {
            "$ref": "./common.schema.json#/$defs/plannerRequestClass"
          },
          "next_action": {
            "$ref": "./common.schema.json#/$defs/interpretationNextAction"
          },
          "normalized_objectives": {
            "$ref": "./common.schema.json#/$defs/stringArray"
          },
          "candidate_descriptors": {
            "$ref": "./common.schema.json#/$defs/stringArray"
          },
          "ambiguities": { "$ref": "./common.schema.json#/$defs/stringArray" },
          "unsupported_phrases": {
            "$ref": "./common.schema.json#/$defs/stringArray"
          },
          "clarification_question": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "rationale": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
          "confidence": { "$ref": "./common.schema.json#/$defs/confidence" }
        }
      }
    },
    "follow_up_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "$ref": "./common.schema.json#/$defs/followUpIntentKind" },
        "rationale": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
      }
    },
    "ambiguities": {
      "$ref": "./common.schema.json#/$defs/stringArray"
    },
    "unsupported_phrases": {
      "$ref": "./common.schema.json#/$defs/stringArray"
    },
    "clarification_question": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "grounding_notes": {
      "$ref": "./common.schema.json#/$defs/stringArray"
    },
    "rationale": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "confidence": {
      "$ref": "./common.schema.json#/$defs/confidence"
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "model", "prompt_version"],
      "properties": {
        "kind": {
          "$ref": "./common.schema.json#/$defs/interpretationProvider"
        },
        "model": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "prompt_version": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "cached": {
          "type": "boolean"
        },
        "response_ms": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "generated_at": {
      "$ref": "./common.schema.json#/$defs/isoTimestamp"
    }
  }
}
