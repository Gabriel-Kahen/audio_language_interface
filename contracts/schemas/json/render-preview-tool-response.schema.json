{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://audio-language-interface.dev/schemas/render-preview-tool-response.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "tool_name", "status", "completed_at"],
  "properties": {
    "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
    "request_id": { "$ref": "./common.schema.json#/$defs/requestId" },
    "tool_name": { "const": "render_preview" },
    "status": { "$ref": "./common.schema.json#/$defs/toolStatus" },
    "completed_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
    "warnings": { "$ref": "./common.schema.json#/$defs/stringArray" },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "command"],
      "properties": {
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "render_id",
            "asset_id",
            "version_id",
            "kind",
            "created_at",
            "output"
          ],
          "properties": {
            "schema_version": { "$ref": "./common.schema.json#/$defs/schemaVersion" },
            "render_id": { "$ref": "./common.schema.json#/$defs/renderId" },
            "asset_id": { "$ref": "./common.schema.json#/$defs/assetId" },
            "version_id": { "$ref": "./common.schema.json#/$defs/versionId" },
            "kind": { "$ref": "./common.schema.json#/$defs/renderKind" },
            "created_at": { "$ref": "./common.schema.json#/$defs/isoTimestamp" },
            "output": { "type": "object" },
            "loudness_summary": { "type": "object" },
            "warnings": { "$ref": "./common.schema.json#/$defs/stringArray" }
          }
        },
        "command": { "$ref": "./common.schema.json#/$defs/toolCommand" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "error" } } },
      "then": { "required": ["error"] }
    },
    {
      "if": { "properties": { "status": { "const": "ok" } } },
      "then": { "required": ["result"] }
    }
  ]
}
